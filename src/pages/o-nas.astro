---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';

const values = [
  {
    title: 'Pasja od pierwszego kęsa',
    desc: 'Pieczenie tortów to nasza życiowa pasja, nie tylko zawód. Każdy projekt traktujemy jak osobiste wyzwanie artystyczne.',
  },
  {
    title: 'Jakość bez kompromisów',
    desc: 'Wybieramy sprawdzonych dostawców, naturalne masło, świeże owoce i najwyższej jakości czekoladę – bez sztucznych polepszaczy.',
  },
  {
    title: 'Indywidualne podejście',
    desc: 'Słuchamy Waszych pomysłów i doradzamy najlepsze rozwiązania, aby tort idealnie pasował do charakteru uroczystości.',
  },
  {
    title: 'Terminowość i zaufanie',
    desc: 'Wiemy, jak ważny jest ten dzień – dlatego dbamy o dokładny harmonogram i bezpieczny transport tortu na miejsce.',
  },
];
---

<Layout
  title="O nas | Torty Natki – pracownia w Elblągu"
  description="Poznaj historię pracowni Torty Natki w Elblągu. Ręcznie robione torty na zamówienie dla Elbląga i okolic, tworzone z pasją i dbałością o najmniejszy detal."
>
  <section class="bg-blush-gradient py-16 sm:py-20">
    <div class="container-site grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="section-eyebrow">O nas</span>
        <h1 class="text-4xl font-semibold sm:text-5xl">Słodka pasja, która stała się rzemiosłem</h1>
        <p class="mt-6 font-body text-lg text-berry-600">
          Torty Natki narodziły się w Elblągu z prostej miłości do pieczenia i dekorowania. To, co zaczęło się jako
          domowe wypieki dla rodziny i przyjaciół, z czasem przerodziło się w pracownię, w której każdego dnia
          tworzymy torty skrojone na miarę najważniejszych chwil w życiu naszych Klientów z Elbląga i okolic.
        </p>
        <p class="mt-4 font-body text-lg text-berry-600">
          Wierzymy, że dobry tort to połączenie sztuki i rzemiosła – dlatego każdy projekt powstaje od szkicu,
          przez dobór smaków, aż po ostatni cukrowy kwiat. Bez pośpiechu, z dbałością o detale, które robią różnicę.
        </p>
      </div>
      <div class="mx-auto w-full max-w-md overflow-hidden rounded-[2.5rem] shadow-soft">
        <img
          src="/images/torty/tort-05-b.jpg"
          alt="Właścicielka pracowni Torty Natki dekorująca ręcznie tort weselny"
          width="1000"
          height="1333"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <span class="section-eyebrow">Nasze wartości</span>
        <h2 class="text-3xl font-semibold sm:text-4xl">Dlaczego warto nam zaufać</h2>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {values.map((v) => (
          <div class="card p-8">
            <h3 class="font-display text-xl font-semibold text-berry-800">{v.title}</h3>
            <p class="mt-3 text-berry-600">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-blush-50/60 py-16 sm:py-20">
    <div class="container-site grid gap-12 lg:grid-cols-2 lg:items-center">
      <div class="order-2 mx-auto w-full max-w-md overflow-hidden rounded-[2.5rem] shadow-soft lg:order-1">
        <img
          src="/images/torty/tort-06.jpg"
          alt="Artystyczny tort 3D wykonany ręcznie w pracowni Torty Natki"
          width="1000"
          height="1333"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="order-1 lg:order-2">
        <span class="section-eyebrow">Jak pracujemy</span>
        <h2 class="text-3xl font-semibold sm:text-4xl">Od pierwszej rozmowy po ostatni kęs</h2>
        <ol class="mt-6 space-y-4 font-body text-berry-600">
          <li><strong class="text-berry-800">1. Rozmowa i wycena</strong> — poznajemy Wasze oczekiwania, styl uroczystości i budżet.</li>
          <li><strong class="text-berry-800">2. Projekt i smaki</strong> — wspólnie dobieramy wygląd, wielkość i ulubione smaki tortu.</li>
          <li><strong class="text-berry-800">3. Realizacja</strong> — pieczemy i dekorujemy tort ręcznie, z użyciem świeżych składników.</li>
          <li><strong class="text-berry-800">4. Dostawa</strong> — bezpiecznie dowozimy tort na miejsce uroczystości, gotowy do podziwiania.</li>
        </ol>
        <div class="mt-8">
          <CTAButton href="/kontakt">Umów się na wycenę</CTAButton>
        </div>
      </div>
    </div>
  </section>
</Layout>
