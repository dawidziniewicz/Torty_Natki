---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';
import CakeCard from '../components/CakeCard.astro';
import { cakes } from '../data/cakes';

const preview = cakes.slice(0, 6);

const usps = [
  {
    icon: '🎂',
    title: 'Ręcznie robione',
    desc: 'Każdy tort powstaje od podstaw, w mojej małej pracowni, z dbałością o najmniejszy detal.',
  },
  {
    icon: '🍓',
    title: 'Świeże składniki',
    desc: 'Naturalne masło, świeże owoce sezonowe i sprawdzone receptury bez sztucznych dodatków.',
  },
  {
    icon: '🎨',
    title: 'Indywidualny projekt',
    desc: 'Każdy tort projektuję razem z Wami – dopasowany do okazji, stylu i marzeń.',
  },
  {
    icon: '🚚',
    title: 'Dowóz na miejsce',
    desc: 'Osobiście dowożę tort prosto na Waszą uroczystość – Elbląg i okolice w promieniu 50 km.',
  },
];

const testimonials = [
  {
    quote: 'Tort na wesele przerósł nasze oczekiwania – wyglądał obłędnie, a smakował jeszcze lepiej. Goście pytali, gdzie go zamówiliśmy!',
    author: 'Kasia i Michał',
  },
  {
    quote: 'Zamawiałam tort urodzinowy dla córki – kontakt błyskawiczny, a efekt zachwycił całą rodzinę. Na pewno wrócę po kolejny.',
    author: 'Ania, Elbląg',
  },
  {
    quote: 'Profesjonalizm w każdym calu – od pierwszej rozmowy telefonicznej po odbiór gotowego tortu. Polecam z czystym sumieniem.',
    author: 'Tomasz, Pasłęk',
  },
];
---

<Layout
  title="Torty Natki | Torty na zamówienie – Elbląg i okolice"
  description="Torty Natki to ręcznie robione torty na zamówienie w Elblągu i okolicach (do 50 km): weselne, urodzinowe i okolicznościowe. Świeże składniki, indywidualny projekt. Zadzwoń: +48 780 086 664."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-blush-gradient">
    <!-- Decorative floating shapes & cakes -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -left-12 -top-12 h-48 w-48 rounded-full bg-candy-200/40 blur-3xl"></div>
      <div class="absolute -right-16 top-1/3 h-64 w-64 rounded-full bg-blush-300/40 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/4 h-40 w-40 rounded-full bg-candy-300/30 blur-3xl"></div>

      <span class="hero-float absolute left-[1%] top-[3%] text-4xl [--float-delay:0s] [--float-duration:6.5s] [--float-rotate:8deg] sm:text-5xl">🎂</span>
      <span class="hero-float absolute left-[88%] top-[18%] text-3xl [--float-delay:1.1s] [--float-duration:5.5s] [--float-rotate:-6deg] sm:text-4xl">🧁</span>
      <span class="hero-float absolute left-[18%] top-[72%] text-3xl [--float-delay:2.3s] [--float-duration:7s] [--float-rotate:10deg] sm:text-4xl">🍰</span>
      <span class="hero-float absolute left-[93%] top-[68%] text-4xl [--float-delay:0.6s] [--float-duration:6s] [--float-rotate:-8deg] sm:text-5xl">🍓</span>
      <span class="hero-float absolute left-[58%] top-[3%] text-2xl [--float-delay:1.8s] [--float-duration:5s] [--float-rotate:12deg] sm:text-3xl">✨</span>
      <span class="hero-float absolute left-[78%] top-[88%] text-3xl [--float-delay:2.9s] [--float-duration:6.8s] [--float-rotate:-10deg] sm:text-4xl">🎂</span>
      <span class="hero-float absolute left-[2%] top-[46%] text-2xl [--float-delay:1.4s] [--float-duration:5.8s] [--float-rotate:6deg] sm:text-3xl">🧁</span>
      <span class="hero-float absolute left-[38%] top-[90%] text-2xl [--float-delay:3.4s] [--float-duration:6.2s] [--float-rotate:-5deg] sm:text-3xl">✨</span>
    </div>

    <div class="container-site relative z-10 grid gap-12 py-16 sm:py-24 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="section-eyebrow">Ręcznie robione torty na zamówienie · Elbląg</span>
        <h1 class="text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl">
          Słodkie arcydzieła<br /> na Wasze wyjątkowe chwile
        </h1>
        <p class="mt-6 max-w-xl font-body text-lg text-berry-600">
          Tworzę torty, które zachwycają wyglądem i&nbsp;smakiem – od kameralnych urodzin po wielkie wesela.
          Działam w&nbsp;Elblągu i&nbsp;okolicach w&nbsp;promieniu 50 km, a&nbsp;każdy projekt powstaje od zera, dopasowany do Waszych marzeń.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <CTAButton href="tel:+48780086664">
            📞 Zadzwoń: +48 780 086 664
          </CTAButton>
          <CTAButton href="/torty" variant="secondary">
            Zobacz galerię tortów
          </CTAButton>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-md">
        <div class="aspect-[4/5] overflow-hidden rounded-[2.5rem] shadow-soft">
          <img
            src="/images/torty/tort-01.jpg"
            alt="Ręcznie robiony tort na zamówienie z różanym wykończeniem od Torty Natki"
            width="1000"
            height="1333"
            class="h-full w-full object-cover"
            fetchpriority="high"
          />
        </div>
        <div class="absolute -bottom-6 -left-6 hidden rounded-2xl bg-white px-6 py-4 shadow-card sm:block">
          <p class="font-display text-2xl font-bold text-candy-600">100%</p>
          <p class="text-xs font-semibold uppercase tracking-wide text-berry-500">zadowolonych Klientów</p>
        </div>
      </div>
    </div>
  </section>

  <!-- USP strip -->
  <section class="py-16 sm:py-20">
    <div class="container-site grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {usps.map((u) => (
        <div class="rounded-2xl bg-white p-6 text-center shadow-card">
          <div class="text-4xl">{u.icon}</div>
          <h3 class="mt-4 font-display text-lg font-semibold text-berry-800">{u.title}</h3>
          <p class="mt-2 text-sm text-berry-600">{u.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Gallery preview -->
  <section class="bg-blush-50/60 py-16 sm:py-20">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <span class="section-eyebrow">Moje realizacje</span>
        <h2 class="text-3xl font-semibold sm:text-4xl">Torty, które zapadają w pamięć</h2>
        <p class="mt-4 font-body text-berry-600">
          Zobaczcie wybrane realizacje z mojej pracowni – od minimalistycznych naked cake’ów po piętrowe torty weselne.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {preview.map((cake) => <CakeCard cake={cake} />)}
      </div>

      <div class="mt-12 text-center">
        <CTAButton href="/torty">Zobacz pełną galerię</CTAButton>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 sm:py-20">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <span class="section-eyebrow">Opinie Klientów</span>
        <h2 class="text-3xl font-semibold sm:text-4xl">Zaufali mi już dziesiątki par i rodzin</h2>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {testimonials.map((t) => (
          <blockquote class="card p-8">
            <p class="font-body italic text-berry-600">&bdquo;{t.quote}&rdquo;</p>
            <footer class="mt-4 font-display font-semibold text-berry-800">— {t.author}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>
</Layout>
