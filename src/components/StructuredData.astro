---
const SITE_URL = 'https://tortynatki.pl';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Bakery',
  name: 'Torty Natki',
  image: `${SITE_URL}/images/torty/tort-01.jpg`,
  '@id': SITE_URL,
  url: SITE_URL,
  telephone: '+48780086664',
  priceRange: '$$',
  servesCuisine: 'Cukiernia, torty na zamówienie',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'PL',
    addressLocality: 'Polska',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '10:00',
      closes: '14:00',
    },
  ],
  sameAs: [],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
